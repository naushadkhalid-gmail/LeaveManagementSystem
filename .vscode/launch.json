{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C#: LeaveManagementSystem [https]",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/LeaveManagementSystem/bin/Debug/net10.0/LeaveManagementSystem.dll",
      "args": [],
      "cwd": "${workspaceFolder}/LeaveManagementSystem",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on: (https?://\\S+)",
        "uriFormat": "%s"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "console": "internalConsole",
      "justMyCode": true
    }
  ]
}
